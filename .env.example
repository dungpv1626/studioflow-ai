# =============================================================
# STUDIO FLOW — AI AGENT SYSTEM — ENVIRONMENT VARIABLES
# =============================================================
# SAO CHÉP FILE NÀY THÀNH .env VÀ ĐIỀN GIÁ TRỊ THỰC
# KHÔNG BAO GIỜ COMMIT FILE .env LÊN GIT
# =============================================================

# --- ANTHROPIC / CLAUDE API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- KIE AI (Image Generation) ---
# Đăng ký tại: https://kie.ai
KIE_AI_API_KEY=kie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIE_AI_BASE_URL=https://api.kie.ai/v1

# --- APIFY (Web Scraping & Data) ---
# Đăng ký tại: https://apify.com
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIFY_BASE_URL=https://api.apify.com/v2

# --- FACEBOOK GRAPH API (Social Media) ---
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# --- STUDIO FLOW BUSINESS INFO ---
BUSINESS_NAME=Studio Flow
BUSINESS_WEBSITE=https://studioflow.vn
BUSINESS_FACEBOOK=https://web.facebook.com/studioflowtech
BUSINESS_ZALO=0965867228
BUSINESS_EMAIL=vietbotaisaas@gmail.com
FOUNDER_NAME=Dũng Phạm

# --- MODEL CONFIGURATION ---
# Mặc định dùng Sonnet 4.6 (cân bằng tốc độ/chất lượng)
# Dùng Opus 4.7 cho các task phân tích phức tạp
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_ANALYSIS_MODEL=claude-opus-4-7
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# --- CONTENT SETTINGS ---
# Ngôn ngữ mặc định cho nội dung
CONTENT_LANGUAGE=vi
CONTENT_TONE=professional_friendly
TARGET_MARKET=Vietnam

# --- CACHE SETTINGS (Prompt Caching) ---
ENABLE_PROMPT_CACHE=true
CACHE_TTL_SECONDS=300

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_FILE=logs/studioflow_agents.log

# --- OPTIONAL: GOOGLE ANALYTICS ---
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret

# --- OPTIONAL: ZALO OA API ---
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_token
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
